<IfModule mod_rewrite.c>
    RewriteEngine On
    
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    RewriteRule ^rss\.xml$ rss.php [L]
    
    RewriteRule ^api$ api.php [L]
    RewriteRule ^api/(.*)$ api.php?$1 [L,QSA]
    
    RewriteRule ^search$ search.php [L]
    RewriteRule ^search/(.*)$ search.php?$1 [L,QSA]
    
    RewriteRule ^post/(\d+)$ index.php?id=$1 [L,QSA]
    RewriteRule ^p/(\d+)$ index.php?id=$1 [L,QSA]
    
    RewriteRule ^page/(\d+)$ index.php?page=$1 [L,QSA]
    
    RewriteRule ^(.*)$ index.php?route=$1 [L,QSA]
</IfModule>

AddDefaultCharset UTF-8

<IfModule mod_php7.c>
    php_flag display_errors off
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|log|ini|conf)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
